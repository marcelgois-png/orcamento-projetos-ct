# Copie este arquivo para .env e preencha os valores reais.
# NÃO versione o .env (já está no .gitignore).

# ── Django ────────────────────────────────────────────────────────────────────
# Gere com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

DEBUG=False

# Hosts permitidos (separados por vírgula). Ex.: irp.ct.ufpb.br,www.irp.ct.ufpb.br
ALLOWED_HOSTS=irp.ct.ufpb.br

# Origens HTTPS confiáveis para CSRF (Django 4+ exige). Ex.: https://irp.ct.ufpb.br
CSRF_TRUSTED_ORIGINS=https://irp.ct.ufpb.br

# ── Banco de dados (MySQL) ────────────────────────────────────────────────────
DB_NAME=irp_db
DB_USER=irp_user
DB_PASSWORD=
DB_ROOT_PASSWORD=
DB_HOST=db
DB_PORT=3306
# Tempo (em segundos) de reuso de conexão. 0 desativa.
DB_CONN_MAX_AGE=60

# ── E-mail (SMTP institucional) ───────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.ufpb.br
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=irp@ct.ufpb.br
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=IRP CT/UFPB <noreply@ct.ufpb.br>

# ── Logging ───────────────────────────────────────────────────────────────────
# Diretório de arquivos de log (rotativos). Deve estar montado como volume no compose.
LOG_DIR=/app/logs
DJANGO_LOG_LEVEL=INFO

# ── Gunicorn ──────────────────────────────────────────────────────────────────
# Recomendado: (2 × nº de CPUs) + 1
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120

# ── Monitoramento (Sentry — opcional) ─────────────────────────────────────────
# Crie um projeto Django em sentry.io e cole o DSN aqui.
# Se vazio, Sentry é ignorado.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
